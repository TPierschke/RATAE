{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run wp-state-machine",
      "type": "debugpy",
      "request": "launch",
      "module": "wp_state_machine",
      "python": "/opt/homebrew/bin/python3",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "python": "/opt/homebrew/bin/python3",
      "args": ["tests/", "-v", "--no-header"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
