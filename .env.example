# WP State Machine — Environment-Variablen
# Kopieren nach .env und anpassen. .env NIEMALS einchecken!

# CMI Zugangsdaten
CMI_HOST=192.168.178.45
CMI_USER=admin
CMI_PASS=admin

# Betrieb
DRY_RUN=true
LOG_LEVEL=INFO
PORT=8765

# Postgres (auf .10)
POSTGRES_URL=postgresql://wp_sm:CHANGEME@192.168.178.10:5432/wp_state_machine

# MQTT (optional, leer lassen zum Deaktivieren)
MQTT_HOST=192.168.178.10
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# Telegram (aus ~/.credentials/)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# FHEM (fuer Watchdog-Checks)
FHEM_HOST=192.168.178.10
FHEM_PORT=8085

# Modbus-Slave (primaere Datenquelle, CMI schreibt aktiv)
# Port wird normalerweise in config.toml konfiguriert
MODBUS_PORT=5020
